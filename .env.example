# Service Identity
SERVICE_NAME=platform-api
API_VERSION=v1
API_PREFIX=api
ENV=production # Use 'dev' for local development with rich logging

# Security
# MUST change this before exposing via ngrok!
API_KEY=change-me-in-production
# Restrict this to your frontend domains in production, e.g. ["https://myapp.com"]
CORS_ORIGINS=["*"]

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json # Use 'rich' for local development

# Concurrency
MAX_WORKERS=4

# Module: Image Factory
MAX_ZIP_SIZE_MB=50
ZIP_STORAGE=/app/data/image_zips
ZIP_EXPIRES_IN=600 # 10 minutes
# ─────────────────────────────────────────────────────
# Web Analyst — Environment Configuration
# Copy this file to .env and fill in values.
# Pillar 2: Zero secrets in source control.
# ─────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ── Browser Pool ──────────────────────────────────────
# Number of concurrent Playwright browser contexts
POOL_SIZE=4

# ── Resilience (Circuit Breaker + Backoff) ────────────
# Circuit breaker: open after N consecutive failures
CB_FAILURE_THRESHOLD=5
# Circuit breaker: seconds before half-open probe
CB_RECOVERY_TIMEOUT=30
# Exponential backoff: max retry attempts
BACKOFF_MAX_ATTEMPTS=5
# Exponential backoff: initial wait (seconds)
BACKOFF_BASE_WAIT=2.0
# Exponential backoff: maximum wait cap (seconds)
BACKOFF_MAX_WAIT=60.0

# ── Job Queue ─────────────────────────────────────────
# Maximum pending analysis tasks (backpressure limit)
MAX_QUEUE_SIZE=100
# Number of concurrent worker coroutines processing jobs
WORKER_COUNT=4

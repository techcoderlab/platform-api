# Service Identity
SERVICE_NAME=platform-api
API_VERSION=v1
API_PREFIX=api
ENV=production # Use 'dev' for local development with rich logging

# Security
# MUST change this before exposing via ngrok!
API_KEY=change-me-in-production
# Restrict this to your frontend domains in production, e.g. ["https://myapp.com"]
CORS_ORIGINS=["*"]

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json # Use 'rich' for local development

# Concurrency
MAX_WORKERS=4

# Module: Image Factory
MAX_ZIP_SIZE_MB=50
ZIP_STORAGE=/app/data/image_zips
ZIP_EXPIRES_IN=600 # 10 minutes
